# ============================================
# SheSafe Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your real keys:
#   cp .env.example .env
#
# NEVER commit the .env file to git!
# ============================================

# Fast2SMS API Key (get from https://www.fast2sms.com → Dev API)
FAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY_HERE

# Google Maps API Key (get from https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/shesafe

# Server port
PORT=3001
